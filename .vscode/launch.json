{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run: daily (1 day)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run: backfill 60 days",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--days", "60"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run: backfill (ask how many days)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--days", "${input:lookbackDays}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "lookbackDays",
      "type": "promptString",
      "description": "How many days back to generate reports for?",
      "default": "60"
    }
  ]
}
